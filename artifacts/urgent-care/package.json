{
  "name": "@workspace/urgent-care",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port ${PORT:-3000}",
    "build": "prisma generate && next build && mkdir -p .next/standalone/artifacts/urgent-care/.next && cp -r .next/static .next/standalone/artifacts/urgent-care/.next/static && cp -r public .next/standalone/artifacts/urgent-care/public",
    "start": "node .next/standalone/artifacts/urgent-care/server.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 playwright test"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "@vis.gl/react-google-maps": "^1.4.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.468.0",
    "next": "15.5.15",
    "next-auth": "^4.24.13",
    "pg": "^8.13.3",
    "prisma": "^7.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
